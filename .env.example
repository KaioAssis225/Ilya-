# === Banco de Dados ===
# O backend acessa via rede interna Docker — use "db" como host
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@db:5432/ilya_db
POSTGRES_PASSWORD=<gere_uma_senha_forte_aqui>

# Pool por processo. Total máximo:
# réplicas × WEB_CONCURRENCY × (DB_POOL_SIZE + DB_MAX_OVERFLOW).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800
DB_COMMAND_TIMEOUT_SECONDS=30
DB_STATEMENT_TIMEOUT_MS=30000
READINESS_TIMEOUT_SECONDS=3

# === Segurança (Argon2id + JWT) ===
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<gere_com_secrets.token_urlsafe(64)>
PASSWORD_PEPPER=<gere_com_secrets.token_urlsafe(64)>

# === Admin inicial (obrigatório para seed_admin.py) ===
ADMIN_EMAIL=admin@suaempresa.com
ADMIN_PASSWORD=<senha_forte_minimo_16_chars>
ADMIN_NAME=Administrador

# === JWT Tokens ===
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7
# Preserva evidências técnicas de rotação/reutilização antes do descarte.
REFRESH_TOKEN_AUDIT_RETENTION_DAYS=30

# Versão/commit exibido nos health checks (defina no deploy).
APP_VERSION=dev

# === CORS ===
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
# Regex restrita aos deployments do Projeto Ilya na Vercel.
BACKEND_CORS_ORIGIN_REGEX=^https://(?:ilya-rust|ilya-[a-z0-9]+-kaioassis225s-projects)\.vercel\.app$

# === Upload de Imagens ===
UPLOAD_DIR=app/static/uploads
MAX_UPLOAD_SIZE_MB=5
MAX_REQUEST_BODY_MB=15
CSV_IMPORT_STATEMENT_TIMEOUT_MS=300000
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
MAX_IMAGE_PIXELS=25000000
MAX_IMAGE_DIMENSION=2560

# === Escala e proteção da API ===
# Local: memory://. Produção com múltiplos workers/réplicas: use Redis.
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_REDIS_TIMEOUT_SECONDS=2
GZIP_MINIMUM_SIZE=1024
GZIP_COMPRESS_LEVEL=5
SLOW_REQUEST_THRESHOLD_MS=1000

# Processos HTTP. Com memory://, mantenha 1. Use 2+ somente depois de
# configurar Redis e validar o limite de conexões do PostgreSQL.
WEB_CONCURRENCY=1
UVICORN_LIMIT_MAX_REQUESTS=10000
UVICORN_LIMIT_CONCURRENCY=100
UVICORN_BACKLOG=2048
FORWARDED_ALLOW_IPS=127.0.0.1,100.0.0.0/8
STARTUP_DB_LOCK_TIMEOUT_SECONDS=1800
STARTUP_MIGRATION_TIMEOUT_SECONDS=900
STARTUP_SEED_TIMEOUT_SECONDS=120

# === Debug (false em produção; true apenas em desenvolvimento local) ===
DEBUG=false

# === Backup operacional (nao e usado pela aplicacao) ===
# Configure somente no ambiente da tarefa de backup; nao grave a URL publica
# nem a senha de criptografia neste arquivo ou no Git.
# PRODUCTION_DATABASE_URL=postgresql://usuario:senha@host:porta/banco
# BACKUP_ENCRYPTION_PASSWORD=<senha_exclusiva_guardada_em_cofre>
