# === Banco de Dados ===
# O backend acessa via rede interna Docker — use "db" como host
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@db:5432/ilya_db
POSTGRES_PASSWORD=<gere_uma_senha_forte_aqui>

# === Segurança (Argon2id + JWT) ===
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<gere_com_secrets.token_urlsafe(64)>
PASSWORD_PEPPER=<gere_com_secrets.token_urlsafe(64)>

# === Admin inicial (obrigatório para seed_admin.py) ===
ADMIN_EMAIL=admin@suaempresa.com
ADMIN_PASSWORD=<senha_forte_minimo_16_chars>
ADMIN_NAME=Administrador

# === JWT Tokens ===
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7
# Preserva evidências técnicas de rotação/reutilização antes do descarte.
REFRESH_TOKEN_AUDIT_RETENTION_DAYS=30

# Versão/commit exibido nos health checks (defina no deploy).
APP_VERSION=dev

# === CORS ===
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# === Upload de Imagens ===
UPLOAD_DIR=app/static/uploads
MAX_UPLOAD_SIZE_MB=5
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# === Debug (false em produção; true apenas em desenvolvimento local) ===
DEBUG=false

# === Backup operacional (nao e usado pela aplicacao) ===
# Configure somente no ambiente da tarefa de backup; nao grave a URL publica
# nem a senha de criptografia neste arquivo ou no Git.
# PRODUCTION_DATABASE_URL=postgresql://usuario:senha@host:porta/banco
# BACKUP_ENCRYPTION_PASSWORD=<senha_exclusiva_guardada_em_cofre>
